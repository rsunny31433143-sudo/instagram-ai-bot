# ---- Meta / Instagram Graph API ----
# From developers.facebook.com after app review approves instagram_manage_messages
IG_PAGE_ACCESS_TOKEN=
IG_BUSINESS_ACCOUNT_ID=
# Any random string you choose - must match what you enter in Meta's webhook config
WEBHOOK_VERIFY_TOKEN=

# ---- AI product detection ----
# Get from console.anthropic.com (used to identify the product in each video frame)
ANTHROPIC_API_KEY=

# ---- Affiliate program IDs (get after each program approves you) ----
AMAZON_ASSOCIATE_TAG=
FLIPKART_AFFILIATE_ID=
MYNTRA_AFFILIATE_ID=

# ---- Server ----
PORT=3000
# Public base URL of this server once deployed (Railway/Render/Vercel give you this)
PUBLIC_BASE_URL=https://your-deployed-app.example.com
